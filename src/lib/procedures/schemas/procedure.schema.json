{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IndustrialProcedure",
  "type": "object",
  "required": ["metadata", "prerequisites", "steps"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["title", "code", "category", "department", "criticality", "version"],
      "properties": {
        "title": { "type": "string" },
        "code": { "type": "string" },
        "category": { "type": "string" },
        "department": { "type": "string" },
        "criticality": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "prerequisites": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "order", "title", "action", "validation"],
        "properties": {
          "id": { "type": "string" },
          "order": { "type": "integer" },
          "title": { "type": "string" },
          "action": { "type": "object" },
          "validation": { "type": "object" }
        }
      }
    },
    "postExecution": { "type": "object" },
    "parameters": { "type": "object" }
  }
}
