
# .vercelignore
# Exclure ChromaDB uniquement lors du déploiement Vercel
node_modules/chromadb/
node_modules/chromadb/**
**/chromadb/**
chroma-data/
*.db
*.sqlite

# Exclure les fichiers de build local
src-tauri/
out/
.next/

# Exclure les dépendances lourdes (chargées dynamiquement en local)
node_modules/better-sqlite3/
node_modules/@huggingface/transformers/
node_modules/onnxruntime-node/

# Exclure les installateurs lourds du build cloud (distribués via redirection API)
public/installers/*.exe
public/installers/*.dmg
public/installers/*.AppImage
