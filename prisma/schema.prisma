// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// 1. GESTION DES UTILISATEURS & ACCRÉDITATIONS
// ---------------------------------------------------------

model User {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  email           String           @unique
  password        String
  role            String           @default("user") // admin, chef-de-bloc, chef-de-quart, user
  approved        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastSyncAt      DateTime?

  // Relations
  knowledgeItems  KnowledgeItem[]
  procedures      Procedure[]
  executions      ProcedureExecution[]

  @@map("users")
}

// ---------------------------------------------------------
// 2. REGISTRE DES PROCÉDURES INDUSTRIELLES
// ---------------------------------------------------------

model Procedure {
  id              String           @id @default(cuid())
  code            String           @unique
  title           String
  description     String?
  category        String           @default("OPERATION")
  subcategory     String?
  department      String           @default("PRODUCTION")
  criticality     String           @default("MEDIUM")
  version         String           @default("1.0.0")
  status          String           @default("APPROVED")
  
  // Données structurées (JSON conforme au format industrial_procedure)
  prerequisites   Json             // { description: string, items: Prerequisite[] }
  steps           Json             // ProcedureStep[]
  parameters      Json?            // { variables: ProcedureVariable[] }
  postExecution   Json?            // { checks: PostExecutionCheck[], reporting: object }
  metadata        Json?            // Métadonnées étendues (tags, author info, etc.)

  // Synchronisation & RAG
  syncedLocal     Boolean          @default(false)
  vectorId        String?          // Référence dans Weaviate/Chroma

  // Audit
  authorId        String
  author          User             @relation(fields: [authorId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastExecutedAt  DateTime?
  executionCount  Int              @default(0)

  // Relations
  executions      ProcedureExecution[]

  @@index([code])
  @@index([category])
  @@index([status])
  @@map("procedures")
}

// ---------------------------------------------------------
// 3. AUDIT D'EXÉCUTION (COCKPIT)
// ---------------------------------------------------------

model ProcedureExecution {
  id              String   @id @default(cuid())
  procedureId     String
  procedure       Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  operatorId      String
  operator        User     @relation(fields: [operatorId], references: [id])
  
  status          String   @default("RUNNING") // RUNNING, COMPLETED, ALARM, FAILED
  currentStep     Int      @default(0)
  stepsStatus     Json     // Etat de validation de chaque étape
  totalDuration   Int?     // Secondes
  
  events          Json?    // Log d'audit (confirmations, alarmes)
  notes           String?
  signature       String?

  startTime       DateTime @default(now())
  endTime         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([procedureId])
  @@index([operatorId])
  @@map("procedure_executions")
}

// ---------------------------------------------------------
// 4. BASE DE CONNAISSANCES RAG (Q/R & DOCUMENTS)
// ---------------------------------------------------------

model KnowledgeItem {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            String   // "qa" ou "text"
  title           String
  question        String?
  answer          String?
  content         String?  // Pour les documents longs
  tags            String[]
  category        String?
  difficulty      String   @default("medium")
  
  isPublic        Boolean  @default(true)
  syncedLocal     Boolean  @default(false)
  vectorId        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("knowledge_items")
}
