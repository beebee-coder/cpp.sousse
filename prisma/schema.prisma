// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"  // ✅ Standard
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String          @id @default(cuid())
  firstName  String
  lastName   String
  password   String
  email      String          @unique
  role       String          @default("user")
  approved   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  lastSyncAt DateTime?

  knowledge KnowledgeItem[]

  @@map("users")
}

/// Stockage unifié des connaissances : paires Q/R et procédures multi-étapes.
/// Utilisé par le RAG IA (Groq + Weaviate) et synchronisé vers ChromaDB local.
model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "qa" | "procedure"
  title       String
  question    String?  // Pour type = "qa"
  answer      String?  // Pour type = "qa"
  steps       Json?    // Pour type = "procedure" : [{order, instruction, mediaUrl?}]
  tags        String[] // Mots-clés pour la recherche
  category    String?
  difficulty  String   @default("medium") // "easy" | "medium" | "hard"
  isPublic    Boolean  @default(true)
  syncedLocal Boolean  @default(false) // true = déjà injecté dans ChromaDB local
  vectorId    String?  // ID dans Weaviate Cloud (pour déduplication)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([syncedLocal])
  @@index([createdAt])
  @@map("knowledge_items")
}