// Configuration Prisma 7 pour VisioNode Core
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "" // Géré par prisma.config.ts et l'adaptateur Neon
}

model User {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  password        String
  email           String           @unique
  role            String           @default("user")
  approved        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastSyncAt      DateTime?
  
  knowledgeItems  KnowledgeItem[]
  procedures      Procedure[]

  @@map("users")
}

model KnowledgeItem {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String           // 'qa' | 'text' | 'manual'
  title           String
  question        String?
  answer          String?
  steps           Json?            // Pour les mini-procédures
  tags            String[]
  category        String?
  difficulty      String           @default("medium")
  isPublic        Boolean          @default(true)
  syncedLocal     Boolean          @default(false)
  vectorId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@map("knowledge_items")
}

model Procedure {
  id              String           @id @default(cuid())
  code            String           @unique
  title           String
  description     String?
  category        String           @default("OPERATION")
  subcategory     String?
  department      String           @default("PRODUCTION")
  criticality     String           @default("MEDIUM")
  version         String           @default("1.0.0")
  status          String           @default("DRAFT")
  
  prerequisites   Json             // Liste structurée des prérequis
  steps           Json             // Liste ordonnée des séquences
  parameters      Json?            // Variables configurables
  postExecution   Json?            // Checks de fin
  metadata        Json             // Métadonnées industrielles
  
  authorId        String
  author          User             @relation(fields: [authorId], references: [id])
  approvers       Json?            // Liste des approbateurs
  
  syncedLocal     Boolean          @default(false)
  lastExecutedAt  DateTime?
  executionCount  Int              @default(0)
  avgDuration     Int?
  successRate     Float?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([code])
  @@index([status])
  @@map("procedures")
}
