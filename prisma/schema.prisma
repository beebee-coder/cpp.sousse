generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  password      String
  email         String    @unique
  role          String    @default("user")
  approved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSyncAt    DateTime?

  knowledgeItems KnowledgeItem[]
  procedures     Procedure[]
  executions     ProcedureExecution[]

  @@map("users")
}

model KnowledgeItem {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // "qa" | "text" | "manual"
  title        String
  question     String?  @db.Text
  answer       String?  @db.Text
  steps        Json?    // Optional structured steps
  tags         String[]
  category     String?
  difficulty   String   @default("medium")
  isPublic     Boolean  @default(true)
  syncedLocal  Boolean  @default(false)
  vectorId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@map("knowledge_items")
}

model Procedure {
  id              String           @id @default(cuid())
  code            String           @unique
  title           String
  description     String?          @db.Text
  category        String           @default("OPERATION")
  subcategory     String?
  department      String           @default("PRODUCTION")
  criticality     String           @default("MEDIUM")
  version         String           @default("1.0.0")
  status          String           @default("DRAFT")
  
  // Structured Industrial Data
  prerequisites   Json             // { description: string, items: Prerequisite[] }
  steps           Json             // ProcedureStep[]
  parameters      Json?            // { variables: ProcedureVariable[] }
  postExecution   Json?            // { checks: PostExecutionCheck[], reporting: object }
  
  // Metadata & Audit
  metadata        Json             // Complete metadata object
  authorId        String
  author          User             @relation(fields: [authorId], references: [id])
  approvers       Json?            // Approver[]
  
  // Sync & RAG
  syncedLocal     Boolean          @default(false)
  vectorId        String?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastExecutedAt  DateTime?
  executionCount  Int              @default(0)

  executions      ProcedureExecution[]

  @@index([code])
  @@index([category])
  @@index([status])
  @@map("procedures")
}

model ProcedureExecution {
  id              String   @id @default(cuid())
  procedureId     String
  procedure       Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  operatorId      String
  operator        User     @relation(fields: [operatorId], references: [id])
  
  startTime       DateTime @default(now())
  endTime         DateTime?
  status          String   // "RUNNING", "COMPLETED", "FAILED", "ALARM"
  currentStep     Int      @default(-1)
  stepsStatus     Json     // Map of step status
  totalDuration   Int?     // In seconds
  
  events          Json?    // Log of events
  alarms          Json?    // Triggered alarms
  
  notes           String?  @db.Text
  signature       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([procedureId])
  @@index([operatorId])
  @@map("procedure_executions")
}
