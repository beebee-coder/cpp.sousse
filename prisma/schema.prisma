// Schema Prisma pour VisioNode Core V7.8 (Support Neon Serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Note : L'URL est gérée dynamiquement via prisma.config.ts sous Prisma 7
}

model User {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  password        String
  email           String           @unique
  role            String           @default("user")
  approved        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastSyncAt      DateTime?
  
  procedures      Procedure[]      @relation("UserProcedures")
  knowledgeItems  KnowledgeItem[]

  @@map("users")
}

model KnowledgeItem {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String
  title           String
  question        String?
  answer          String?
  steps           Json?
  tags            String[]
  category        String?
  difficulty      String           @default("medium")
  isPublic        Boolean          @default(true)
  syncedLocal     Boolean          @default(false)
  vectorId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@map("knowledge_items")
}

model Procedure {
  id              String           @id @default(cuid())
  code            String           @unique
  title           String
  description     String?
  category        String           @default("OPERATION")
  subcategory     String?
  department      String           @default("PRODUCTION")
  criticality     String           @default("MEDIUM")
  version         String           @default("1.0.0")
  status          String           @default("DRAFT")
  
  prerequisites   Json
  steps           Json
  parameters      Json?
  postExecution   Json?
  metadata        Json
  
  authorId        String
  author          User             @relation("UserProcedures", fields: [authorId], references: [id])
  approvers       Json?
  
  syncedLocal     Boolean          @default(false)
  lastExecutedAt  DateTime?
  executionCount  Int              @default(0)
  avgDuration     Int?
  successRate     Float?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([code])
  @@index([status])
  @@map("procedures")
}
