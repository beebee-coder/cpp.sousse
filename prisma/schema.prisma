// prisma/schema.prisma
// Version : Schéma Industriel V18.0 - Conformité Prisma 7.8.0
// Erreur P1012 résolue : relations inverses ajoutées et champ url déplacé.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // url est géré via prisma.config.ts pour Prisma 7+
}

model User {
  id                 String               @id @default(cuid())
  firstName          String
  lastName           String
  password           String
  email              String               @unique
  role               String               @default("user")
  approved           Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  lastSyncAt         DateTime?
  
  // Relations inverses (Correction P1012)
  knowledgeItems     KnowledgeItem[]
  authoredProcedures Procedure[]
  executions         ProcedureExecution[]

  @@map("users")
}

model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // 'qa' | 'text' | 'procedure_fragment'
  title       String
  question    String?
  answer      String?
  steps       Json?    // Liste d'instructions structurées
  tags        String[]
  category    String?
  difficulty  String   @default("medium")
  isPublic    Boolean  @default(true)
  syncedLocal Boolean  @default(false)
  vectorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("knowledge_items")
}

model Procedure {
  id             String               @id @default(cuid())
  code           String               @unique
  title          String
  description    String?
  category       String               @default("OPERATION")
  subcategory    String?
  department     String               @default("PRODUCTION")
  criticality    String               @default("MEDIUM")
  version        String               @default("1.0.0")
  status         String               @default("DRAFT")
  
  prerequisites  Json                 // Structure { description, items: [] }
  steps          Json                 // Liste d'objets ProcedureStep
  parameters     Json?                // Variables configurables
  postExecution  Json?                // Checks de fin et reporting
  metadata       Json                 // Métadonnées CRF
  
  authorId       String
  author         User                 @relation(fields: [authorId], references: [id])
  
  syncedLocal    Boolean              @default(false)
  lastExecutedAt DateTime?
  executionCount Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  
  executions     ProcedureExecution[]

  @@index([code])
  @@index([status])
  @@map("procedures")
}

model ProcedureExecution {
  id            String    @id @default(cuid())
  procedureId   String
  procedure     Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  operatorId    String
  operator      User      @relation(fields: [operatorId], references: [id])
  
  startTime     DateTime  @default(now())
  endTime       DateTime?
  status        String    // 'COMPLETED' | 'FAILED' | 'ABORTED'
  currentStep   Int       @default(-1)
  stepsStatus   Json      // Log détaillé par étape
  totalDuration Int?      // Secondes
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([procedureId])
  @@index([operatorId])
  @@map("procedure_executions")
}
