generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  password      String
  email         String    @unique
  role          String    @default("user")
  approved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSyncAt    DateTime?

  knowledgeItems KnowledgeItem[]
  procedures     Procedure[]
  executions     ProcedureExecution[]

  @@map("users")
}

model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  question    String?
  answer      String?
  steps       Json?
  tags        String[]
  category    String?
  difficulty  String   @default("medium")
  isPublic    Boolean  @default(true)
  syncedLocal Boolean  @default(false)
  vectorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("knowledge_items")
}

model Procedure {
  id              String   @id @default(cuid())
  code            String   @unique
  title           String
  description     String?
  category        String   @default("OPERATION")
  subcategory     String?
  department      String   @default("PRODUCTION")
  criticality     String   @default("MEDIUM")
  version         String   @default("1.0.0")
  status          String   @default("DRAFT")
  prerequisites   Json
  steps           Json
  parameters      Json?
  postExecution   Json?
  metadata        Json
  authorId        String
  approvers       Json?
  syncedLocal     Boolean  @default(false)
  lastExecutedAt  DateTime?
  executionCount  Int      @default(0)
  avgDuration     Int?
  successRate     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])
  executions ProcedureExecution[]

  @@index([code])
  @@index([status])
  @@map("procedures")
}

model ProcedureExecution {
  id              String    @id @default(cuid())
  procedureId     String
  operatorId      String
  startTime       DateTime  @default(now())
  endTime         DateTime?
  status          String
  currentStep     Int       @default(-1)
  stepsStatus     Json
  totalDuration   Int?
  events          Json?
  alarms          Json?
  fallbacks       Json?
  result          Json?
  notes           String?
  signature       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  procedure Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  operator  User      @relation(fields: [operatorId], references: [id])

  @@index([procedureId])
  @@index([operatorId])
  @@map("procedure_executions")
}