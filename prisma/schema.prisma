generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  password      String
  role          String    @default("user") // "admin", "chef-de-bloc", "chef-de-quart", "user"
  approved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  knowledgeItems KnowledgeItem[]
  procedures     Procedure[]
  executions     ProcedureExecution[]
}

model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "qa" | "procedure"
  title       String
  question    String?
  answer      String?
  steps       Json?    // Structure simplifiée pour Q/A
  tags        String[]
  category    String?
  difficulty  String   @default("medium")
  isPublic    Boolean  @default(true)
  syncedLocal Boolean  @default(false)
  vectorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([type])
}

model Procedure {
  id              String           @id @default(cuid())
  code            String           @unique
  title           String
  description     String?
  category        String           // "STARTUP", "MAINTENANCE", etc.
  subcategory     String?
  department      String           // "PRODUCTION", "MAINTENANCE", etc.
  criticality     String           // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  version         String           @default("1.0.0")
  status          String           @default("DRAFT") // "DRAFT", "APPROVED", "PUBLISHED"
  
  // Données industrielles structurées
  prerequisites   Json             // Format: { description: string, items: Prerequisite[] }
  steps           Json             // Format: ProcedureStep[]
  parameters      Json?            // Format: { variables: ProcedureVariable[] }
  postExecution   Json?            // Format: { checks: PostExecutionCheck[], reporting: object }
  metadata        Json             // Métadonnées complètes pour RAG
  
  authorId        String
  author          User             @relation(fields: [authorId], references: [id])
  approvers       Json?            // Historique des approbations
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastExecutedAt  DateTime?
  executionCount  Int              @default(0)
  avgDuration     Int?
  successRate     Float?
  
  executions      ProcedureExecution[]
  alarms          ProcedureAlarm[]
  documents       ProcedureDocument[]

  @@index([code])
  @@index([category])
}

model ProcedureExecution {
  id              String   @id @default(cuid())
  procedureId     String
  procedure       Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  operatorId      String
  operator        User     @relation(fields: [operatorId], references: [id])
  
  startTime       DateTime @default(now())
  endTime         DateTime?
  status          String   // "RUNNING", "COMPLETED", "FAILED", "ALARM"
  currentStep     Int      @default(-1)
  stepsStatus     Json     // Suivi détaillé par étape
  totalDuration   Int?
  
  events          Json?    // Log technique
  alarms          Json?    // Alertes déclenchées
  fallbacks       Json?    // Modes dégradés utilisés
  
  notes           String?
  signature       String?  // Signature numérique opérateur
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([procedureId])
  @@index([operatorId])
}

model ProcedureAlarm {
  id              String    @id @default(cuid())
  procedureId     String
  procedure       Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  code            String
  type            String    // "WARNING", "CRITICAL"
  severity        String
  description     String
  remedy          Json      // Protocole de résolution
  condition       String    // Expression logique
  triggeredAt     DateTime?
  resolvedAt      DateTime?
  status          String    @default("ACTIVE")
  
  createdAt       DateTime  @default(now())
}

model ProcedureDocument {
  id              String    @id @default(cuid())
  procedureId     String
  procedure       Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  title           String
  type            String    // "IMAGE", "VIDEO", "PDF"
  url             String
  caption         String?
  uploadedBy      String
  uploadedAt      DateTime  @default(now())
}
