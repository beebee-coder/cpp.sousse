
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  password        String
  email           String           @unique
  role            String           @default("user")
  approved        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastSyncAt      DateTime?

  // Relations
  knowledgeItems  KnowledgeItem[]
  procedures      Procedure[]
  executions      ProcedureExecution[]

  @@map("users")
}

model KnowledgeItem {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String           // "qa" | "text"
  title           String
  question        String?
  answer          String?
  steps           Json?            // Pour stockage structuré si besoin
  tags            String[]
  category        String?
  difficulty      String           @default("medium")
  isPublic        Boolean          @default(true)
  syncedLocal     Boolean          @default(false)
  vectorId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([type])
  @@map("knowledge_items")
}

model Procedure {
  id              String           @id @default(cuid())
  code            String           @unique
  title           String
  description     String?
  category        String           @default("OPERATION")
  subcategory     String?
  department      String           @default("PRODUCTION")
  criticality     String           @default("MEDIUM")
  version         String           @default("1.0.0")
  status          String           @default("DRAFT")
  
  // Données structurées
  prerequisites   Json             // { description: string, items: Prerequisite[] }
  steps           Json             // ProcedureStep[]
  parameters      Json?            // { variables: ProcedureVariable[] }
  postExecution   Json?            // { checks: [], reporting: {} }
  
  // Métadonnées
  metadata        Json?            // { authorId: string, tags: string[], ... }
  authorId        String
  author          User             @relation(fields: [authorId], references: [id])
  approvers       Json?            // Approver[]
  
  // Audit
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastExecutedAt  DateTime?
  executionCount  Int              @default(0)
  syncedLocal     Boolean          @default(false)
  
  // Relations
  executions      ProcedureExecution[]

  @@index([code])
  @@index([category])
  @@map("procedures")
}

model ProcedureExecution {
  id              String   @id @default(cuid())
  procedureId     String
  procedure       Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  operatorId      String
  operator        User     @relation(fields: [operatorId], references: [id])
  
  startTime       DateTime @default(now())
  endTime         DateTime?
  status          String   @default("RUNNING")
  stepsStatus     Json     // Record<stepId, status>
  totalDuration   Int?     // En secondes
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([procedureId])
  @@index([operatorId])
  @@map("procedure_executions")
}
