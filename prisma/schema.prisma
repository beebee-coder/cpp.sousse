// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String      @id @default(cuid())
  firstName       String
  lastName        String
  password        String
  email           String      @unique
  role            String      @default("user")
  approved        Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastSyncAt      DateTime?

  knowledgeItems  KnowledgeItem[]
  procedures      Procedure[]
  executions      ProcedureExecution[]
}

model KnowledgeItem {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // "qa" | "procedure"
  title        String
  question     String?
  answer       String?
  steps        Json?
  tags         String[]
  category     String?
  difficulty   String   @default("medium")
  isPublic     Boolean  @default(true)
  syncedLocal  Boolean  @default(false)
  vectorId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([syncedLocal])
}

model Procedure {
  id              String           @id @default(cuid())
  code            String           @unique
  title           String
  description     String?
  category        String           // STARTUP, SHUTDOWN, etc.
  subcategory     String?
  department      String           // PRODUCTION, MAINTENANCE, etc.
  criticality     String           // LOW, MEDIUM, HIGH, CRITICAL
  version         String           @default("1.0.0")
  status          String           @default("DRAFT") // DRAFT, REVIEW, APPROVED, etc.
  
  // Données structurées industrielles
  prerequisites   Json             // Liste des prérequis
  steps           Json             // Liste des étapes
  parameters      Json?            // Paramètres configurables
  postExecution   Json?            // Post-exécution
  
  // Métadonnées
  metadata        Json             
  authorId        String
  author          User             @relation(fields: [authorId], references: [id])
  approvers       Json?            // Liste des approbateurs
  
  // Audit & Performance
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastExecutedAt  DateTime?
  executionCount  Int              @default(0)
  avgDuration     Int?             // Temps moyen d'exécution en secondes
  successRate     Float?           // Taux de succès
  
  // Relations
  executions      ProcedureExecution[]

  @@index([code])
  @@index([category])
  @@index([status])
}

model ProcedureExecution {
  id              String   @id @default(cuid())
  procedureId     String
  procedure       Procedure @relation(fields: [procedureId], references: [id])
  operatorId      String
  operator        User     @relation(fields: [operatorId], references: [id])
  
  // Détails de la session
  startTime       DateTime @default(now())
  endTime         DateTime?
  status          String   // IDLE, RUNNING, COMPLETED, ALARM, etc.
  currentStep     Int      @default(-1)
  stepsStatus     Json     // Statut détaillé de chaque étape
  totalDuration   Int?     // Durée totale en secondes
  
  // Événements d'audit
  events          Json?    // Log des événements
  alarms          Json?    // Alarmes déclenchées
  fallbacks       Json?    // Fallbacks utilisés
  
  // Résultats finaux
  result          Json?    // Résultat technique final
  notes           String?
  signature       String?  // Signature numérique de l'opérateur
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([procedureId])
  @@index([operatorId])
  @@index([status])
}
