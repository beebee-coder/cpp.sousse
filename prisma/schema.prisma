// Modèle de données Prisma pour VisioNode
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  // ... (champs existants gérés par prisma/apply-schema.ts)
}
