generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  chef_de_bloc
  chef_de_quart
  user
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  firstName     String?
  lastName      String?
  password      String
  role          Role      @default(user)
  approved      Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSyncAt    DateTime?
  
  // Relations inverses pour Prisma 5/7
  authoredProcedures Procedure[]
  executions         ProcedureExecution[]
  knowledgeItems     KnowledgeItem[]

  @@map("users")
}

model Procedure {
  id             String    @id @default(cuid())
  title          String
  code           String    @unique
  description    String?
  category       String
  criticality    String    @default("NORMAL")
  status         String    @default("DRAFT")
  steps          Json      // Stockage structuré des étapes CRF
  prerequisites  Json?
  authorId       String
  author         User      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastExecutedAt DateTime?
  executionCount Int       @default(0)
  subcategory    String?
  department     String?
  version        String?
  parameters     Json?
  postExecution  Json?
  metadata       Json?
  mediaLibrary   Json?

  executions     ProcedureExecution[] @relation("ProcedureToExecutions")
  versions       ProcedureVersion[]
  alarms         ProcedureAlarm[]
  documents      ProcedureDocument[]
  media          ProcedureMedia[]

  @@map("procedures")
  @@index([category])
  @@index([status])
  @@index([criticality])
}

model ProcedureExecution {
  id            String   @id @default(cuid())
  procedureId   String
  operatorId    String
  status        String   @default("COMPLETED")
  stepsStatus   Json?
  totalDuration Int?      @default(0)
  endTime       DateTime? @default(now())
  startTime     DateTime? @default(now())
  currentStep   Int?
  alarms        Json?
  fallbacks     Json?
  events        Json?
  signature     String?
  
  operator      User      @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  procedure     Procedure @relation("ProcedureToExecutions", fields: [procedureId], references: [id], onDelete: Cascade)
  
  @@map("procedure_executions")
}

model ProcedureVersion {
  id           String   @id @default(cuid())
  procedureId  String
  procedure    Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  version      String
  changes      String
  snapshot     Json
  createdAt    DateTime @default(now())
  createdBy    String

  @@map("procedure_versions")
  @@index([procedureId])
}

model ProcedureAlarm {
  id          String   @id @default(cuid())
  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  code        String
  type        String
  severity    String
  description String
  remedy      Json
  condition   String
  triggeredAt DateTime?
  resolvedAt  DateTime?
  status      String   @default("ACTIVE")

  createdAt   DateTime @default(now())

  @@map("procedure_alarms")
  @@index([procedureId])
}

model ProcedureDocument {
  id          String   @id @default(cuid())
  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  title       String
  type        String
  url         String
  caption     String?
  uploadedBy  String
  uploadedAt  DateTime @default(now())

  @@map("procedure_documents")
  @@index([procedureId])
}

model ProcedureMedia {
  id           String   @id @default(cuid())
  procedureId  String
  procedure    Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  kind         String
  source       String
  title        String
  description  String?
  url          String
  thumbnailUrl String?
  mimeType     String
  fileSize     Int?
  duration     Float?
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())
  createdBy    String

  @@map("procedure_media")
  @@index([procedureId])
}

model KnowledgeItem {
  id        String   @id @default(cuid())
  title     String
  type      String   // 'document', 'qa', 'snippet'
  content   String?
  question  String?
  answer    String?
  tags      String[]
  category  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_items")
  @@index([category])
}

model ChatMessage {
  id             String   @id @default(cuid())
  clientId       String?
  conversationId String
  userId         String
  role           String
  content        String
  provider       String?
  timestamp      DateTime @default(now())
  media          Json?
  procedureId    String?
  source         String?

  @@unique([conversationId, userId, clientId])
  @@index([conversationId, userId])
  @@map("chat_messages")
}

model ProcedureFieldTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // 'text', 'number', 'boolean', 'select'
  description String?
  options     Json?    // Optional list of choices if type is 'select'
  required    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("procedure_field_templates")
}
