// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  password      String
  role          String    @default("user")
  approved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSyncAt    DateTime?
  
  procedures    Procedure[]
  knowledgeItems KnowledgeItem[]
  executions    ProcedureExecution[]

  @@map("users")
}

model Procedure {
  id              String   @id @default(cuid())
  code            String   @unique
  title           String
  description     String?
  category        String   @default("OPERATION")
  subcategory     String?
  department      String   @default("PRODUCTION")
  criticality     String   @default("MEDIUM")
  version         String   @default("1.0.0")
  status          String   @default("DRAFT")
  
  prerequisites   Json     // Standard CRF items
  steps           Json     // Standard CRF steps
  parameters      Json?
  postExecution   Json?
  metadata        Json     // Comprehensive metadata
  
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastExecutedAt  DateTime?
  executionCount  Int      @default(0)
  
  executions      ProcedureExecution[]

  @@map("procedures")
  @@index([code])
  @@index([status])
}

model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   @default("qa")
  title       String
  question    String?
  answer      String?
  steps       Json?
  tags        String[]
  category    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("knowledge_items")
  @@index([userId])
}

model ProcedureExecution {
  id              String    @id @default(cuid())
  procedureId     String
  procedure       Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  operatorId      String
  operator        User      @relation(fields: [operatorId], references: [id])
  
  startTime       DateTime  @default(now())
  endTime         DateTime?
  status          String
  currentStep     Int       @default(-1)
  stepsStatus     Json
  totalDuration   Int?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("procedure_executions")
  @@index([procedureId])
  @@index([operatorId])
}
