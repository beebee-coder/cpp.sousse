generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String          @id @default(uuid())
  firstName  String
  lastName   String
  password   String
  email      String          @unique
  role       String          @default("user")
  approved   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  lastSyncAt DateTime?
  items      KnowledgeItem[]

  @@map("users")
}

model KnowledgeItem {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  question    String?
  answer      String?
  steps       Json?
  tags        String[]
  category    String?
  difficulty  String   @default("medium")
  isPublic    Boolean  @default(true)
  syncedLocal Boolean  @default(false)
  vectorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([syncedLocal])
  @@index([createdAt])
  @@map("knowledge_items")
}
