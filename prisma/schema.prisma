generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  chef_de_bloc
  chef_de_quart
  user
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  firstName     String?
  lastName      String?
  password      String
  role          Role      @default(user)
  approved      Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSyncAt    DateTime?
  
  // Relations inverses pour Prisma 5/7
  authoredProcedures Procedure[]
  executions         ProcedureExecution[]
  knowledgeItems     KnowledgeItem[]

  @@map("users")
}

model Procedure {
  id             String    @id @default(cuid())
  title          String
  code           String    @unique
  description    String?
  category       String
  criticality    String    @default("NORMAL")
  status         String    @default("DRAFT")
  steps          Json      // Stockage structuré des étapes CRF
  prerequisites  Json?
  authorId       String
  author         User      @relation(fields: [authorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastExecutedAt DateTime?
  executionCount Int       @default(0)

  executions     ProcedureExecution[]

  @@map("procedures")
}

model ProcedureExecution {
  id            String    @id @default(cuid())
  procedureId   String
  operatorId    String
  status        String    @default("COMPLETED")
  stepsStatus   Json?
  totalDuration Int?      @default(0)
  endTime       DateTime? @default(now())
  startTime     DateTime? @default(now())
  
  operator      User      @relation(fields: [operatorId], references: [id])
  procedure     Procedure @relation(fields: [procedureId], references: [id])
  
  @@map("procedure_executions")
}

model KnowledgeItem {
  id        String   @id @default(cuid())
  title     String
  type      String   // 'document', 'qa', 'snippet'
  content   String?
  question  String?
  answer    String?
  tags      String[]
  category  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_items")
}

model ProcedureFieldTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // 'text', 'number', 'boolean', 'select'
  description String?
  options     Json?    // Optional list of choices if type is 'select'
  required    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("procedure_field_templates")
}
