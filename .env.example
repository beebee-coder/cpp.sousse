# --- LIAISON IA PRIORITAIRE (LPU) ---
# Obtenir sur : https://console.groq.com/
GROQ_API_KEY=votre_cle_groq_ici

# --- LIAISON IA REPLI (MULTIMODAL) ---
# Obtenir sur : https://aistudio.google.com/
GOOGLE_GENAI_API_KEY=votre_cle_google_genai_ici

# --- LIAISON REGISTRE GITHUB ---
# Utilisé pour la synchronisation et le déploiement auto
# Obtenir un "Fine-grained token" sur GitHub
GITHUB_TOKEN=votre_github_token_ici

# --- CHROMADB (Base de données vectorielle locale) ---
# Lancer le serveur avec : npm run chroma:start
CHROMA_URL=http://127.0.0.1:8000

# --- CONFIGURATION FIREBASE ---
# Utilisé pour la base de données et l'audit distant
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Cloud / PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
POSTGRES_HOST=postgres.vercel.com
POSTGRES_PORT=5432
POSTGRES_DB=visionode
POSTGRES_USER=postgres
POSTGRES_PASSWORD=********
VERCEL_API_URL=https://visionode.vercel.app/api

# Local
CHROMA_DB_PATH=./chroma-data
SQLITE_DB_PATH=./data/visionode.sqlite