
# -----------------------------------------------------------------------------
# VisioNode - Exemple de Configuration des Liaisons Externes
# Copiez ce fichier vers .env et renseignez vos clés pour activer les services.
# -----------------------------------------------------------------------------

# --- LIAISON IA PRIORITAIRE (LPU) ---
# Obtenir sur : https://console.groq.com/
GROQ_API_KEY=votre_cle_groq_ici

# --- LIAISON IA REPLI (MULTIMODAL) ---
# Obtenir sur : https://aistudio.google.com/
GOOGLE_GENAI_API_KEY=votre_cle_gemini_ici

# --- LIAISON REGISTRE GITHUB ---
# Utilisé pour la synchronisation et le déploiement auto
# Obtenir un "Fine-grained token" sur GitHub
GITHUB_TOKEN=votre_token_github_ici

# --- CONFIGURATION FIREBASE ---
# Utilisé pour la base de données et l'audit distant
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
