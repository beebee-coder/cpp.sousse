          "id": "fallback-003",
          "title": "Ouverture manuelle de la vanne",
          "description": "Utilisation de la commande manuelle de secours",
          "condition": "valve_auto_open FAILED",
          "action": "Passer en mode manuel, ouvrir la vanne à 30% via la pompe hydraulique manuelle",
          "estimatedTime": 300
        }
      ],
