      },
      "alarms": [
        {
          "id": "alarm-003",
          "code": "CRF-003",
          "type": "warning",
          "severity": "medium",
          "description": "Fin de l'ouverture de vanne imminente",
          "condition": "time_elapsed >= 44",
          "remedy": {
            "title": "Préparation à la fin d'ouverture",
            "description": "L'ouverture de la vanne touche à sa fin, préparez-vous pour la phase de stabilisation",
