  "prerequisites": {
    "description": "Conditions obligatoires avant le démarrage de la procédure",
    "items": [
      {
        "id": "pr-001",
        "description": "Niveau du bassin d'aspiration supérieur à -5,00 m",
        "condition": "level > -5.00",
        "expectedState": "OK",
        "verificationType": "manual",
        "displayName": "Niveau bassin d'aspiration",
        "unit": "m",
        "threshold": -5,
        "operator": ">",
        "manualCheckInstruction": "Veuillez vérifier visuellement le niveau du bassin d'aspiration et confirmer qu'il est supérieur à moins cinq mètres"
      },
      {
        "id": "pr-002",
        "description": "Unité hydraulique 001 GO opérationnelle",
        "condition": "hydraulic_unit_001 == ON",
        "expectedState": "OK",
        "verificationType": "manual",
        "displayName": "État unité hydraulique",
        "manualCheckInstruction": "Veuillez vérifier que l'unité hydraulique 001 GO est opérationnelle et confirmer son état"
      },
      {
        "id": "pr-003",
        "description": "Vanne d'aspiration manuelle ouverte",
        "condition": "valve_aspiration == OPEN",
        "expectedState": "OK",
        "verificationType": "manual",
        "displayName": "Position vanne aspiration",
        "expectedPosition": "OPEN",
        "manualCheckInstruction": "Veuillez vérifier que la vanne d'aspiration manuelle est ouverte et confirmer sa position"
      },
      {
        "id": "pr-004",
        "description": "Vanne clapet de refoulement initialement fermée",
        "condition": "valve_discharge == CLOSED",
        "expectedState": "OK",
        "verificationType": "manual",
        "displayName": "Position vanne refoulement",
        "expectedPosition": "CLOSED",
        "manualCheckInstruction": "Veuillez vérifier que la vanne clapet de refoulement est fermée et confirmer sa position"
      }
    ]
  },
  "steps": [
    {
      "id": "step-001",
      "order": 1,
      "title": "Lavage de la grille rotative CFI",
      "subtitle": "Séquence automatique de nettoyage",
      "description": "L'ordre de démarrage lance automatiquement une séquence de lavage de la grille rotative CFI. Le moteur ne sera mis sous tension qu'après 6 minutes de lavage.",
      "duration": {
        "value": 360,
        "unit": "seconds",
        "display": "6 minutes",
        "type": "fixed"
      },
      "action": {
        "type": "confirmation",
        "instruction": "Vérifier que la séquence de lavage CFI est bien en cours d'exécution",
        "expectedConfirmation": "Séquence de lavage démarrée",
        "ui": {
          "component": "confirmation_button",
          "label": "Confirmer le lavage",
          "icon": "check_circle"
        }
      },
      "validation": {
        "conditions": [
          {
            "id": "val-001",
            "description": "Perte de charge à travers la grille rotative",
            "type": "pressure",
            "operator": "<",
            "value": 200,
            "unit": "mmCE",
            "displayName": "Perte de charge grille",
            "monitoring": true
          }
        ],
        "successExpression": "pressure_diff < 200",
        "timeout": {
          "value": 420,
          "unit": "seconds",
          "action": "abort"
        }
      },
      "alarms": [
        {
          "id": "alarm-001",
          "code": "CFI-001",
          "type": "warning",
          "severity": "high",
          "description": "Perte de charge excessive sur la grille rotative",
          "condition": "pressure_diff >= 200",
          "remedy": {
            "title": "Nettoyage manuel de la grille",
            "description": "Arrêter la pompe, isoler la section, procéder au nettoyage manuel de la grille rotative",
            "steps": [
              "Arrêter la pompe CRF",
              "Isoler la section de la grille",
              "Ouvrir le carter d'inspection",
              "Nettoyer manuellement la grille",
              "Refermer le carter",
              "Désisoler la section",
              "Reprendre la procédure"
            ],
            "estimatedTime": 600,
            "tools": [
              "Brosse métallique",
              "Chiffon",
              "Nettoyant industriel"
            ],
            "safety": [
              "Gants",
              "Lunettes de protection"
            ]
          },
          "escalation": {
            "ifPersistsAfter": 2,
            "contact": "supervisor",
            "message": "Perte de charge CFI persistante - Inspection requise"
          },
          "triggerBeforeEnd": 60
        }
      ],
      "fallbacks": [
        {
          "id": "fallback-001",
          "title": "Dérivation de la grille CFI",
          "description": "Si le nettoyage manuel ne résout pas le problème, utiliser la ligne de dérivation",
          "condition": "pressure_diff >= 200 AND manual_cleaning_attempts >= 2",
          "action": "Ouvrir la vanne de dérivation, fermer les vannes d'isolement de la grille",
          "estimatedTime": 120
        }
      ],
      "dependencies": {
        "prerequisites": [
          "pr-001",
          "pr-002",
          "pr-003",
          "pr-004"
        ],
        "dependsOn": [],
        "requiresConfirmation": true
      },
      "media": {
        "image": {
          "url": "/media/procedures/crf/grille-cfi.jpg",
          "caption": "Grille rotative CFI - Vue générale",
          "alt": "Photo de la grille rotative CFI"
        },
        "diagram": {
          "url": "/media/procedures/crf/cfi-diagram.pdf",
          "caption": "Schéma de la séquence CFI"
        },
        "video": {
          "url": "/media/procedures/crf/cfi-cleaning.mp4",
          "caption": "Vidéo de démonstration du lavage CFI"
        }
      },
      "notes": [
        "Vérifier visuellement le démarrage du lavage",
        "Écouter les bruits anormaux",
        "Surveiller les indicateurs de pression"
      ]
    },
    {
      "id": "step-002",
      "order": 2,
      "title": "Mise sous tension du moteur CRF",
      "subtitle": "Activation du moteur principal",
      "description": "Mise sous tension du moteur de la pompe CRF après 6 minutes de lavage CFI",
      "duration": {
        "value": 10,
        "unit": "seconds",
        "display": "10 secondes",
        "type": "fixed"
      },
      "action": {
        "type": "command",
        "instruction": "Lancer la mise sous tension du moteur CRF depuis la salle de contrôle",
        "command": "START_MOTOR",
        "parameters": {
          "motorId": "CRF-M-001",
          "startMode": "automatic"
        },
        "ui": {
          "component": "action_button",
          "label": "Démarrer le moteur",
          "icon": "play_arrow",
          "color": "success"
        }
      },
      "validation": {
        "conditions": [
          {
            "id": "val-002",
            "description": "Moteur en fonctionnement",
            "type": "status",
            "operator": "==",
            "value": "RUNNING",
            "displayName": "État du moteur"
          },
          {
            "id": "val-003",
            "description": "Tension nominale atteinte",
            "type": "voltage",
            "operator": ">=",
            "value": 380,
            "unit": "V",
            "displayName": "Tension moteur"
          }
        ],
        "successExpression": "motor_status == RUNNING AND voltage >= 380",
        "timeout": {
          "value": 30,
          "unit": "seconds",
          "action": "abort"
        }
      },
      "alarms": [
        {
          "id": "alarm-002",
          "code": "CRF-002",
          "type": "warning",
          "severity": "medium",
          "description": "Fin de la mise sous tension imminente",
          "condition": "time_elapsed >= 5",
          "remedy": {
            "title": "Préparation à la fin de la mise sous tension",
            "description": "La mise sous tension touche à sa fin, préparez-vous pour l'étape suivante",
            "steps": [
              "Surveiller les indicateurs de tension",
              "Préparer les commandes pour l'étape suivante"
            ],
            "estimatedTime": 60
          },
          "escalation": {
            "ifPersistsAfter": 1,
            "contact": "electrical_team",
            "message": "Fin de mise sous tension - Préparation étape suivante"
          },
          "triggerBeforeEnd": 5
        },
        {
          "id": "alarm-002b",
          "code": "CRF-002B",
          "type": "critical",
          "severity": "critical",
          "description": "Défaut de mise sous tension du moteur CRF",
          "condition": "motor_status == FAULT OR voltage < 380",
          "remedy": {
            "title": "Diagnostic électrique du moteur",
            "description": "Vérifier les alimentations, les protections et les circuits de commande",
            "steps": [
              "Vérifier la présence de tension en amont",
              "Contrôler les disjoncteurs et fusibles",
              "Tester les circuits de commande",
              "Vérifier le SSR (Solid State Relay)",
              "Contrôler l'enroulement du moteur",
              "Réarmer si nécessaire"
            ],
            "estimatedTime": 300,
            "tools": [
              "Multimètre",
              "Pince ampèremétrique",
              "Plans électriques"
            ],
            "safety": [
              "Équipement électrique isolé",
              "Vérifier l'absence de tension"
            ]
          },
          "escalation": {
            "ifPersistsAfter": 1,
            "contact": "electrical_team",
            "message": "Défaut électrique CRF persistant"
          }
        }
      ],
      "fallbacks": [
        {
          "id": "fallback-002",
          "title": "Démarrage manuel du moteur",
          "description": "Utilisation du mode manuel pour le démarrage",
          "condition": "motor_start_automatic FAILED",
          "action": "Passer en mode manuel, démarrer le moteur via le pupitre local",
          "estimatedTime": 180
        }
      ],
      "dependencies": {
        "prerequisites": [],
        "dependsOn": [
          "step-001"
        ],
        "requiresConfirmation": true
      },
      "media": {
        "video": {
          "url": "/media/procedures/crf/motor-start.mp4",
          "caption": "Vidéo de démarrage du moteur CRF"
        }
      },
      "notes": [
        "Surveiller les courants de démarrage",
        "Écouter les bruits du moteur",
        "Vérifier le sens de rotation"
      ]
    },
    {
      "id": "step-003",
      "order": 3,
      "title": "Ouverture vanne de refoulement - Palier 1",
      "subtitle": "Phase d'ouverture rapide 0→30%",
      "description": "Ouverture rapide de la vanne de refoulement de 0% à 30% en 54 secondes",
      "duration": {
        "value": 54,
        "unit": "seconds",
        "display": "54 secondes",
        "type": "fixed",
        "animation": true
      },
      "action": {
        "type": "valve_operation",
        "instruction": "Lancer l'ouverture rapide de la vanne UV-101 vers 30%",
        "valveId": "UV-101",
        "operation": "open",
        "target": 30,
        "speed": "rapid",
        "parameters": {
          "rampTime": 54,
          "intermediateChecks": true
        },
        "ui": {
          "component": "valve_control",
          "label": "Ouvrir vanne (30%)",
          "icon": "valve_open",
          "showProgress": true,
          "progressDuration": 54
        }
      },
      "validation": {
