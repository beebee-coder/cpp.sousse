    {
      "id": "step-005",
      "order": 5,
      "title": "Ouverture finale vanne - Palier 3",
      "subtitle": "Phase d'ouverture 30→100%",
      "description": "Ouverture finale de 30% à 100% en 126 secondes",
      "duration": {
        "value": 126,
        "unit": "seconds",
        "display": "2 minutes 6 secondes",
        "type": "fixed"
      },
      "action": {
        "type": "valve_operation",
        "instruction": "Lancer l'ouverture finale de la vanne UV-101 vers 100%",
        "valveId": "UV-101",
        "operation": "open",
        "target": 100,
        "speed": "progressive",
        "parameters": {
          "rampTime": 126,
          "intermediateChecks": true,
          "checkInterval": 30
        },
        "ui": {
          "component": "valve_control",
          "label": "Ouvrir vanne (100%)",
          "icon": "valve_open_full",
          "showProgress": true,
