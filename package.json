{
  "name": "visionode",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:tauri": "cross-env TAURI_ENV=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf out .next src-tauri/target",
    "desktop:build": "npm run build:tauri && npx tauri build",
    "postinstall": "prisma generate",
    "seed": "tsx -r dotenv/config prisma/seed.ts",
    "seed:prod": "NODE_ENV=production tsx -r dotenv/config prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force",
    "db:deploy": "prisma migrate deploy"
  },
