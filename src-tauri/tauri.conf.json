{
  "productName": "VisioNode",
  "version": "1.0.0",
  "identifier": "com.visionode.precision.engine",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:tauri",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "VisioNode Control Center",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://api.groq.com; font-src 'self' data:; frame-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "CCP Industrial Vision",
    "category": "DeveloperTool",
    "shortDescription": "VisioNode Control Center - Industrial Vision Platform",
    "longDescription": "Plateforme de contrôle par vision industrielle hybride avec audit de flux intelligent.",
    "copyright": "© CCP Industrial Vision - Tous droits réservés",

    "windows": {
      "nsis": {
        "installMode": "perMachine"
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": false
      }
    }
  },
  "plugins": {
    "deep-link": {
      "schemes": ["visionode"]
    }
  }
}
